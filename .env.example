# MOCK_MODE=false → live Claude API (requires ANTHROPIC_API_KEY and billing)
# PROMPT_CACHE=true → reuse cached council instructions across API calls (default)
# TOKEN_BUDGET=0 → unlimited (shows rem as ∞); set e.g. 500000 for a session-day cap
MOCK_MODE=true
PROMPT_CACHE=true
TOKEN_BUDGET=0
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# COUNCIL_ROSTER=arabi,morrison,kierkegaard  (exactly 3; blake available as backup)
COUNCIL_ROSTER=arabi,morrison,kierkegaard
